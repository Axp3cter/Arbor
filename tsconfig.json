{
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "downlevelIteration": true,
        "jsx": "react",
        "jsxFactory": "Roact.createElement",
        "jsxFragmentFactory": "Roact.createFragment",
        "module": "commonjs",
        "moduleResolution": "Node",
        "noLib": true,
        "resolveJsonModule": true,
        "strict": true,
        "target": "ESNext",
        "typeRoots": ["node_modules/@rbxts"],
        "declaration": true,
        "declarationDir": "out",
        "outDir": "out",
        "rootDir": "src"
    },
    "include": ["src/**/*.d.ts"]
}
